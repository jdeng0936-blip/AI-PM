# AI-PM 开发环境配置
AIPM_ENV=dev

# 数据库（开发用 Docker 容器，端口 5433 避开已有 PG）
DATABASE_URL=postgresql+asyncpg://aipm:devpass@localhost:5433/aipm_db
POSTGRES_PASSWORD=devpass

# Redis（端口 6380 避开已有 Redis）
REDIS_URL=redis://localhost:6380/0

# 企业微信（开发阶段先用占位符，联调时替换）
WECHAT_CORP_ID=ww_placeholder
WECHAT_CORP_SECRET=placeholder_secret
WECHAT_AGENT_ID=1000001
WECHAT_TOKEN=dev_token_placeholder
WECHAT_ENCODING_AES_KEY=0123456789012345678901234567890123456789012

# NewApi 大模型网关（开发阶段先用占位符）
NEW_API_BASE_URL=http://localhost:3001/v1
NEW_API_KEY=sk-dev-placeholder
NEW_API_MODEL=gemini-1.5-pro

# Token 限流
DAILY_TOKEN_LIMIT=500000

# 安全
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
