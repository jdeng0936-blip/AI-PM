# ============================================================
# 徽远成 AI-PM 环境配置模板
# 复制本文件为 .env，填写真实值后使用。不要将 .env 提交至 Git。
# ============================================================

# 运行环境（dev = 自动建表 | prod = 必须先执行 alembic upgrade head）
AIPM_ENV=dev

# 数据库（PostgreSQL 15+）
DATABASE_URL=postgresql+asyncpg://aipm:your_pg_password@localhost:5432/aipm_db

# 缓存（Redis）
REDIS_URL=redis://localhost:6379/0

# ── 企业微信配置 ────────────────────────────────────────────
# 企业 ID（管理后台 > 我的企业）
WECHAT_CORP_ID=ww_your_corp_id

# 自建应用 Secret（应用管理 > 自建 > 应用详情）
WECHAT_CORP_SECRET=your_app_secret

# 自建应用 AgentId
WECHAT_AGENT_ID=1000001

# 企业可信 IP 回调 Token（接收消息 > 设置 API 接收）
WECHAT_TOKEN=your_callback_token

# 消息加解密 EncodingAESKey（43位）
WECHAT_ENCODING_AES_KEY=your_43_char_aes_key

# ── NewApi（大模型网关）──────────────────────────────────────
NEW_API_BASE_URL=http://your-newapi-host/v1
NEW_API_KEY=sk-your-newapi-key
NEW_API_MODEL=gemini-1.5-pro

# ── Token 限流熔断 ───────────────────────────────────────────
# 每日最大 Token 消耗量（默认 50万）
DAILY_TOKEN_LIMIT=500000

# ── 对象存储 OSS（用于企微素材转存）───────────────────────────
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_BUCKET=huiyuancheng-aipm-media
OSS_ACCESS_KEY=your_oss_access_key
OSS_SECRET_KEY=your_oss_secret_key

# ── 安全配置 ────────────────────────────────────────────────
# JWT 签名密钥（建议用 openssl rand -hex 32 生成）
JWT_SECRET_KEY=change-me-to-a-secure-random-string
